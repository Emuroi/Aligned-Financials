{
  "name": "aligned-financials-desktop",
  "version": "0.1.8",
  "description": "Private offline desktop workspace for Aligned Financials.",
  "author": "Aligned Financials",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis portable",
    "dist:installer": "node scripts/build-windows.js",
    "dist:portable": "electron-builder --win portable",
    "dist:publish": "node scripts/build-windows.js --publish",
    "release:notes": "node scripts/make-release-notes.js",
    "version:bump:patch": "node scripts/bump-version.js patch",
    "version:bump:minor": "node scripts/bump-version.js minor",
    "version:bump:major": "node scripts/bump-version.js major",
    "release:prepare:patch": "npm run version:bump:patch && npm run release:notes",
    "release:prepare:minor": "npm run version:bump:minor && npm run release:notes",
    "release:prepare:major": "npm run version:bump:major && npm run release:notes",
    "release:test": "npm run dist:installer",
    "release:ship": "npm run dist:publish"
  },
  "build": {
    "appId": "com.alignedfinancials.desktop",
    "productName": "Aligned Financials",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "app/**/*",
      "main.js",
      "preload.js",
      "package.json",
      "README.md"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Emuroi",
        "repo": "Aligned-Financials",
        "publishAutoUpdate": true
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Aligned-Financials-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "Aligned-Financials-Portable-${version}.${ext}"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
