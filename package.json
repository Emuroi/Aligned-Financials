{
  "name": "aligned-financials-desktop",
  "version": "0.1.0",
  "description": "Private offline desktop workspace for Aligned Financials.",
  "author": "Aligned Financials",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis portable",
    "dist:installer": "electron-builder --win nsis",
    "dist:portable": "electron-builder --win portable",
    "dist:publish": "electron-builder --win nsis --publish always"
  },
  "build": {
    "appId": "com.alignedfinancials.desktop",
    "productName": "Aligned Financials",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "app/**/*",
      "main.js",
      "preload.js",
      ".env",
      ".env.example",
      "package.json",
      "README.md"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Emuroi",
        "repo": "Alligned-Financials"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Aligned-Financials-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "Aligned-Financials-Portable-${version}.${ext}"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
