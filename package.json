{
  "name": "aligned-financials-desktop",
  "version": "0.1.0",
  "description": "Private offline desktop workspace for Aligned Financials.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis portable"
  },
  "build": {
    "appId": "com.alignedfinancials.desktop",
    "productName": "Aligned Financials",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "app/**/*",
      "main.js",
      "preload.js",
      "package.json",
      "README.md"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Aligned-Financials-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "Aligned-Financials-Portable-${version}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
